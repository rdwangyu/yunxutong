.page { padding-bottom: 40rpx; }

/* Hero */
.hero {
  position: relative;
  height: 460rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, #1a3a4a 0%, #2c5f7e 50%, #4a90d9 100%);
}
.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}
.hero-badge {
  background: rgba(255,255,255,0.15);
  padding: 6rpx 24rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  display: block;
  margin-bottom: 20rpx;
}
.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
}
.hl { color: #7fc8ff; }
.hero-intro {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 16rpx;
}
.hero-btn {
  margin-top: 40rpx;
  background: #4a90d9;
  color: #fff;
  font-size: 28rpx;
  padding: 18rpx 52rpx;
  border-radius: 50rpx;
  font-weight: 600;
}
.hero-btn::after { border: none; }

/* Section */
.section {
  padding: 44rpx 30rpx;
  background: #fff;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}
.section-desc {
  font-size: 27rpx;
  color: #555;
  line-height: 1.8;
  display: block;
}
.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}
.badge {
  background: #f0f7ff;
  border: 1rpx solid #4a90d9;
  color: #4a90d9;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* Services */
.services {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-top: 10rpx;
}
.service-item {
  background: #f7faff;
  border-radius: 14rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 1rpx solid #e8f0fe;
}
.s-icon { font-size: 44rpx; display: block; margin-bottom: 8rpx; }
.s-title {
  font-size: 26rpx;
  font-weight: 600;
  display: block;
}

/* Advantages */
.highlight-section {
  background: linear-gradient(135deg, #1a3a4a, #2c5f7e);
  margin-bottom: 0;
}
.advantages {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}
.adv-item {
  background: rgba(255,255,255,0.08);
  border-radius: 14rpx;
  padding: 24rpx 20rpx;
  text-align: center;
}
.adv-icon { font-size: 44rpx; display: block; margin-bottom: 8rpx; }
.adv-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}
.adv-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  display: block;
  margin-top: 6rpx;
  line-height: 1.5;
}

/* Bottom CTA */
.bottom-cta {
  padding: 30rpx;
  text-align: center;
}
.cta-btn {
  width: 100%;
  background: #4a90d9;
  color: #fff;
  padding: 22rpx 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.cta-btn::after { border: none; }
