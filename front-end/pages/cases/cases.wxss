.page { padding-bottom: 30rpx; }

.page-header {
  padding: 40rpx 30rpx 10rpx;
  background: #fff;
}
.page-title { font-size: 36rpx; font-weight: 700; display: block; }
.page-sub { font-size: 26rpx; color: #888; display: block; margin-top: 6rpx; }
.hl { color: #4a90d9; }

.cases-grid {
  padding: 20rpx 30rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.case-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.case-img-wrap {
  position: relative;
  width: 100%;
  height: 230rpx;
}
.case-img { width: 100%; height: 100%; }
.play-overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}
.play-icon {
  width: 60rpx; height: 60rpx;
  background: rgba(74,144,217,0.85);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}
.case-body {
  padding: 16rpx;
}
.case-title {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
  display: block;
}
.case-meta {
  font-size: 20rpx;
  color: #aaa;
  display: block;
  margin-top: 4rpx;
}

/* Video popup */
.video-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
}
.video-popup {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  z-index: 101;
  padding-bottom: 24rpx;
}
.video-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}
.video-popup-title {
  font-size: 30rpx;
  font-weight: 700;
  flex: 1;
}
.video-popup-close {
  font-size: 36rpx;
  color: #999;
  padding: 0 10rpx;
  font-weight: 300;
}
.video-player { display: block; }
.video-popup-desc {
  font-size: 24rpx;
  color: #777;
  display: block;
  padding: 16rpx 24rpx 0;
  line-height: 1.6;
}
