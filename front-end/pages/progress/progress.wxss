.page { padding-bottom: 40rpx; }

.project-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 24rpx 30rpx 0;
}
.project-title { font-size: 36rpx; font-weight: 700; display: block; }
.project-meta { font-size: 24rpx; color: #888; display: block; margin-top: 8rpx; }

.progress-bar-wrap { margin-top: 28rpx; }
.pb-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx; }
.pb-label { font-size: 28rpx; font-weight: 500; color: #333; }
.pb-percent { font-size: 40rpx; font-weight: 800; color: #4a90d9; }
.pb-track {
  width: 100%; height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}
.pb-fill {
  height: 100%;
  background: linear-gradient(90deg, #4a90d9, #1a3a4a);
  border-radius: 10rpx;
}

.stages {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 16rpx 30rpx 0;
}
.stage-item { display: flex; gap: 20rpx; min-height: 80rpx; }
.stage-left { display: flex; flex-direction: column; align-items: center; width: 44rpx; }
.stage-dot {
  width: 44rpx; height: 44rpx; min-width: 44rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700; color: #fff;
}
.stage-item.done .stage-dot { background: #28a745; }
.stage-item.current .stage-dot { background: #4a90d9; }
.stage-item:not(.done):not(.current) .stage-dot { background: #e0e0e0; color: #999; }
.stage-line { width: 2rpx; flex: 1; background: #e0e0e0; }
.stage-item.done .stage-line { background: #28a745; }
.stage-item.current .stage-line { background: #e0e0e0; }
.stage-body {
  flex: 1; padding-bottom: 24rpx;
  display: flex; flex-direction: column; justify-content: center;
}
.stage-name { font-size: 28rpx; font-weight: 500; display: block; color: #bbb; }
.stage-item.done .stage-name { color: #28a745; font-weight: 600; }
.stage-name.cur-name { color: #4a90d9; font-weight: 700; }
.stage-date { font-size: 22rpx; color: #ccc; display: block; margin-top: 4rpx; }
.stage-item.done .stage-date { color: #28a745; }

.photos {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 16rpx 30rpx 0;
}
.photos-title { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 16rpx; }
.photos-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8rpx;
}
.photo-img {
  width: 100%;
  height: 150rpx;
  border-radius: 8rpx;
}
