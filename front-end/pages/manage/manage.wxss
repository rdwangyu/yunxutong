.page { padding-bottom: 40rpx; }

.profile {
  background: linear-gradient(135deg, #1a3a4a, #2c5f7e);
  padding: 48rpx 30rpx;
}
.profile-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  margin-bottom: 6rpx;
}
.profile-name {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}
.profile-address {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-top: 12rpx;
}

.menu-section {
  background: #fff;
  border-radius: 16rpx;
  margin: 24rpx 30rpx 0;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
}
.menu-icon { font-size: 40rpx; width: 48rpx; text-align: center; }
.menu-body { flex: 1; }
.menu-title {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
}
.menu-desc {
  font-size: 22rpx;
  color: #aaa;
  display: block;
  margin-top: 2rpx;
}
.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

.logout-section {
  padding: 40rpx 30rpx;
  text-align: center;
}
.logout-btn {
  width: 100%;
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  padding: 20rpx 0;
  border-radius: 14rpx;
  font-size: 28rpx;
}
.logout-btn::after { border: none; }
